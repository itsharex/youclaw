{
  "name": "youclaw",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "Desktop AI assistant powered by Claude",
  "repository": {
    "type": "git",
    "url": "https://github.com/CodePhiliaX/youClaw"
  },
  "author": {
    "name": "CodePhiliaX",
    "email": "huanyueyaoqin@qq.com"
  },
  "license": "ISC",
  "scripts": {
    "dev": "bun run src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "dev:web": "cd web && bun run dev",
    "dev:tauri": "bun tauri dev",
    "build:sidecar": "bun scripts/build-sidecar.mjs",
    "build:tauri": "bun run build:sidecar && bun tauri build",
    "test": "bun test '.test.'",
    "test:e2e": "bunx playwright test --config e2e/playwright.config.ts",
    "test:e2e:ui": "bunx playwright test --config e2e/playwright.config.ts --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2",
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.72",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "croner": "^10.0.1",
    "fflate": "^0.8.2",
    "grammy": "^1.41.1",
    "hono": "^4.12.6",
    "minimatch": "^10.0.1",
    "pino": "^10.3.1",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  }
}
