{
  "name": "youclaw",
  "version": "1.0.0",
  "main": "dist/electron/main/index.js",
  "type": "module",
  "private": true,
  "description": "Desktop AI assistant powered by Claude",
  "repository": {
    "type": "git",
    "url": "https://github.com/CodePhiliaX/youClaw"
  },
  "author": {
    "name": "CodePhiliaX",
    "email": "huanyueyaoqin@qq.com"
  },
  "license": "ISC",
  "scripts": {
    "dev": "tsx --watch src/index.ts",
    "start": "node --import tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "dev:web": "cd web && npm run dev",
    "test:e2e": "npx playwright test --config e2e/playwright.config.ts",
    "test:e2e:ui": "npx playwright test --config e2e/playwright.config.ts --ui",
    "dev:electron": "node scripts/dev-electron.mjs",
    "pack": "node scripts/build-electron.mjs && electron-builder --dir && codesign --force --deep --sign - release/mac-arm64/You\\ Claw.app",
    "dist": "node scripts/build-electron.mjs && electron-builder",
    "publish": "node scripts/build-electron.mjs && electron-builder --publish always"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.16.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.72",
    "@hono/node-server": "^1.14.3",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "croner": "^10.0.1",
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "fflate": "^0.8.2",
    "grammy": "^1.41.1",
    "hono": "^4.12.6",
    "minimatch": "^10.0.1",
    "pino": "^10.3.1",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  }
}
