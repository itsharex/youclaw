# Anthropic
ANTHROPIC_BASE_URL=
ANTHROPIC_API_KEY=your-api-key

# Server
PORT=3000

# Data
DATA_DIR=./data

# Agent
AGENT_MODEL=claude-sonnet-4-6

# Logging
LOG_LEVEL=info

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Cloud service (leave empty for offline mode)
# YOUCLAW_WEBSITE_URL=
# YOUCLAW_API_URL=

# Built-in model (injected at compile time)
# YOUCLAW_BUILTIN_API_URL=
# YOUCLAW_BUILTIN_AUTH_TOKEN=

MINIMAX_API_KEY=
MINIMAX_API_HOST=
