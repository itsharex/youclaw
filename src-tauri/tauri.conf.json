{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "You Claw",
  "version": "1.0.0",
  "identifier": "com.youclaw.app",
  "build": {
    "beforeDevCommand": "cd web && bun run dev & bun run ../src/index.ts & wait",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "cd web && bun run build",
    "frontendDist": "../web/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "You Claw",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "targets": "all",
    "externalBin": [
      "bin/youclaw-server"
    ],
    "resources": [
      "../agents/**/*",
      "../skills/**/*",
      "../prompts/**/*",
      "../node_modules/@anthropic-ai/claude-agent-sdk/cli.js"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installMode": "both",
        "languages": ["SimpChinese", "English"]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://UPDATER_ENDPOINT_PLACEHOLDER/releases/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJGNkVEQjU0NTk0REM5MQpSV1NSM0pSRnRlMzJBdWtwUm1oWjdxVjZmS2xHTG1PMHRBZ1l3bThUaXhPZFo4VldBdEpya1U3cwo="
    }
  }
}
